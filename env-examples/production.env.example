# Production-ready environment example for Wavo services
# These values are example-generated placeholders to help you deploy quickly.
# Replace values with your real production endpoints and rotate all secrets.
# DO NOT commit real secrets to Git. Store them in Dokploy Secrets or your
# platform's secret manager and rotate regularly.

### Database (Postgres) #######################################################
# Use managed Postgres for production. Include sslmode if required by provider.
DATABASE_URL=postgresql://wavo_user:V9t8K3mP2qLz7rX@db-prod.wavo.example.com:5432/wavo_prod?schema=public&sslmode=require
DATABASE_POOL_SIZE=20

### Redis #####################################################################
# Use managed Redis (e.g., Valkey, Upstash) when possible.
REDIS_URL=rediss://:R3d1sS3cr3t!#2@redis-prod.wavo.example.com:6380

### Object Storage (S3 / MinIO) ##############################################
MINIO_ENDPOINT=minio-prod.wavo.example.com
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=minio_prod_user
MINIO_SECRET_KEY=Minio$Prod#2026
MINIO_BUCKET=wavo-storage

### Auth & Security ###########################################################
# Prefer RS256 keys (PEM) for production. If using PEM, store as multiline string
# or escape newlines as \n if the UI doesn't accept multiline secrets.
## JWT configuration
## You can use RS256 (PEM keys) or HS256 (symmetric secret). If you prefer
## RS256, store the PEM in JWT_PRIVATE_KEY (escaped \n or multiline) and
## JWT_PUBLIC_KEY with the public key. The example below uses HS256-style
## symmetric secret for convenience — replace with PEM-based keys if needed.
JWT_PRIVATE_KEY=Kp9X7sN4vQyR8tZ2bM6uF1wL0eH3cG5n
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AES encryption key (exactly 32 characters, hex or base64 as your app expects)
ENCRYPTION_KEY=6f2b9c3a8d1e4f5a6b7c8d9e0f1a2b3c
BCRYPT_ROUNDS=12

### Application / Network ####################################################
NODE_ENV=production
PORT=4000
API_URL=https://api.wavo.example.com
FRONTEND_URL=https://app.wavo.example.com
ADMIN_EMAIL=admin@wavo.example.com

### Observability & Logs #####################################################
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

### Optional Integrations ####################################################
# Email (SMTP)
SMTP_HOST=smtp.mail.example.com
SMTP_PORT=587
SMTP_USER=smtp_user
SMTP_PASS=SmTpPa$$2026
SMTP_FROM=noreply@wavo.example.com

# Third-party service keys
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

### Frontend-specific (NEXT_PUBLIC_* values) ###################################
# These are included here for convenience; frontends only read NEXT_PUBLIC_* vars.
NEXT_PUBLIC_API_URL=https://api.wavo.example.com
NEXT_PUBLIC_WS_URL=wss://api.wavo.example.com
NEXT_PUBLIC_APP_NAME=Wavo

### Notes ####################################################################
# 1) Keep this file out of version control if it contains secrets. Commit only
#    as `.env.production.example` with placeholders like this file.
# 2) If a secret contains newlines (PEM), and your secret UI disallows multiline,
#    replace newlines with literal `\n` sequences and ensure your runtime
#    reconstructs them (e.g., `key.replace(/\\n/g, "\n")`).
# 3) Use managed DB/Redis/Storage for production for reliability and backups.
