# ═══════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════
DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/wavo?schema=public
DATABASE_POOL_SIZE=20

# ═══════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════
# AUTH & SECURITY
# ═══════════════════════════════════════════
# RS256 Private / Public keys (PEM format) or standard HS256 string for local dev
JWT_PRIVATE_KEY="wavo_secure_session_encryption_key_32_bytes_long_secret"
JWT_PUBLIC_KEY="wavo_secure_session_encryption_key_32_bytes_long_secret"
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ENCRYPTION_KEY="wavo_secure_session_encryption_key_32_bytes_long_secret" # Exactly 32 characters
BCRYPT_ROUNDS=12

# ═══════════════════════════════════════════
# GOOGLE OAUTH (Optional for development)
# ═══════════════════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# ═══════════════════════════════════════════
# OBJECT STORAGE (Falls back to local /storage if empty)
# ═══════════════════════════════════════════
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_root
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET=wavo-storage
MINIO_USE_SSL=false

# ═══════════════════════════════════════════
# EMAIL (SMTP)
# ═══════════════════════════════════════════
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@wavo.dev

# ═══════════════════════════════════════════
# OBSERVABILITY & LOGS
# ═══════════════════════════════════════════
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info # trace | debug | info | warn | error | fatal

# ═══════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
ADMIN_EMAIL=admin@wavo.dev
